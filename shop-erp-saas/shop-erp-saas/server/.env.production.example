# ===== Server production environment =====
# Copy this to `.env` on your VPS and fill in the real values.
# NEVER commit the real .env to git (it is gitignored).

PORT=5000
NODE_ENV=production

# MongoDB Atlas connection string.
# Use a NEW rotated password (the old one was exposed) and lock Atlas
# Network Access to your VPS IP only.
MONGO_URI=mongodb+srv://<db_user>:<new_password>@<cluster-host>/shop_erp_saas?retryWrites=true&w=majority&authSource=admin

# Long random secret used to sign JWTs. Generate a fresh one with:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=<generate_a_long_random_secret>

# Token lifetime. 7d is a good balance for an ERP handling money.
JWT_EXPIRE=7d

# Your live frontend URL (used for CORS). Must match the domain users visit.
CLIENT_URL=https://yourshop.com

# Cloudinary — image storage for logos & employee photos.
# Get these from your Cloudinary dashboard (Settings > API Keys).
CLOUDINARY_CLOUD_NAME=<your_cloud_name>
CLOUDINARY_API_KEY=<your_api_key>
CLOUDINARY_API_SECRET=<your_api_secret>

# Encrypts tenant marketing credentials (SMS/SMTP/AI keys) at rest.
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# NOTE: changing this later makes already-saved credentials unreadable (owners must re-enter them).
ENCRYPTION_KEY=<generate_a_long_random_secret>

# ===== Central FREE AI keys (platform-funded) =====
# Set one or BOTH and every shop gets AI (dashboard summary + marketing copy)
# for free — no per-shop setup. Tried in order Gemini -> Groq, so if one is
# rate-limited/down the other takes over automatically.
# Gemini free key: https://aistudio.google.com/apikey
GEMINI_API_KEY=
# Optional model override (default: gemini-2.0-flash)
GEMINI_MODEL=
# Groq free key: https://console.groq.com/keys
GROQ_API_KEY=
# Optional model override (default: llama-3.3-70b-versatile)
GROQ_MODEL=
