# ===== Client production environment =====
# Copy this to `.env` (or `.env.production`) before running `npm run build`.
# Vite bakes these values into the static build at build time, so you must
# rebuild after changing them.

# Your live API base URL. With the Nginx setup, /api is proxied to Node,
# so this is just your domain + /api.
VITE_API_URL=https://yourshop.com/api

# WhatsApp number for the floating support button (country code, no +).
VITE_WHATSAPP_NUMBER=8801XXXXXXXXX
